# =============================================================================
# Secrets — never commit
# =============================================================================
.env

# =============================================================================
# Virtual environment
# =============================================================================
.venv/
venv/
env/
.Python

# =============================================================================
# Python cache
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Outputs — contain personal data (resumes, cover letters, parsed JSON)
# =============================================================================
outputs/

# =============================================================================
# Candidate documents — personal files, never commit real resumes
# =============================================================================
*.pdf
*.docx
# Exclude plain-text resumes and job descriptions (personal data)
resume*.txt
resume_text.txt
job_desc*.txt

# =============================================================================
# IDE / OS
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# Logs
# =============================================================================
*.log
