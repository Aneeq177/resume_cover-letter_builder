# Copy this file to .env and fill in your actual API keys.
# Never commit .env — it is listed in .gitignore.

# =============================================================================
# LLM provider — switch between Anthropic (production) and Ollama (local testing)
# =============================================================================
# Options: "anthropic" (default) | "ollama"
LLM_PROVIDER=anthropic

# --- Ollama (local testing) --------------------------------------------------
# Only used when LLM_PROVIDER=ollama.
# Run `ollama pull llama3.2` (or any model) before using.
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1   # default; change if Ollama runs elsewhere

# =============================================================================
# Anthropic — powers all five agents when LLM_PROVIDER=anthropic
# Get yours at: https://console.anthropic.com/account/keys
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# =============================================================================
# Serper — web search used by the Job Analyst agent
# Get yours at: https://serper.dev
# =============================================================================
SERPER_API_KEY=...

# =============================================================================
# Voyage AI — used for embeddings (required even when memory=False)
# Get yours at: https://www.voyageai.com
# =============================================================================
VOYAGE_API_KEY=pa-...
