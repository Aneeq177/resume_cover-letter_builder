# Copy this file to .env and fill in your actual API keys.
# Never commit .env — it is listed in .gitignore.

# Anthropic — powers all five agents
# Get yours at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Serper — web search used by the Job Analyst agent
# Get yours at: https://serper.dev
SERPER_API_KEY=...

# Voyage AI — used for embeddings (required even when memory=False)
# Get yours at: https://www.voyageai.com
VOYAGE_API_KEY=pa-...
